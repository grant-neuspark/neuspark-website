---
const { current } = Astro.props;
---

<header class="border-b border-white/10 bg-zinc-950 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-6 py-5 flex justify-between items-center">
    <a href="/" class="flex items-center gap-3">
      <img src="/neuspark-logo.png" alt="NeuSpark" class="h-10 w-auto">
      <span class="text-2xl font-bold tracking-tight">neuspark</span>
    </a>

    <nav class="hidden md:flex gap-8 text-sm uppercase tracking-widest">
      <a href="/" class={current === 'home' ? 'text-amber-400' : 'hover:text-amber-400 transition'}>Home</a>
      <a href="/about" class={current === 'about' ? 'text-amber-400' : 'hover:text-amber-400 transition'}>About</a>
      <a href="/services" class={current === 'services' ? 'text-amber-400' : 'hover:text-amber-400 transition'}>Services</a>
      <a href="/blog" class={current === 'blog' ? 'text-amber-400' : 'hover:text-amber-400 transition'}>Blog</a>
      <a href="/contact" class={current === 'contact' ? 'text-amber-400' : 'hover:text-amber-400 transition'}>Contact</a>
    </nav>

    <a href="/contact" class="bg-amber-400 hover:bg-amber-500 text-black px-6 py-3 rounded-full font-semibold transition text-sm">
      Work With Me
    </a>
  </div>
</header>
