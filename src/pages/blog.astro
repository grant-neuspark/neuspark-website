---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Header current="blog" />

  <section class="pt-24 pb-20">
    <div class="max-w-4xl mx-auto px-6">
      <h1 class="text-5xl font-bold tracking-tighter mb-16 text-center">Insights & Articles</h1>
      <p class="text-center text-zinc-400 mb-12">Practical wisdom for personal transformation</p>

      <div class="text-center py-20 text-zinc-500">
        Blog posts will appear here.<br>
        I'll help you add your first articles easily.
      </div>
    </div>
  </section>

  <Footer />
</Layout>
