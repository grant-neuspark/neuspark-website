---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Header current="contact" />

  <section class="pt-24 pb-32 bg-zinc-950">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <h1 class="text-5xl font-bold tracking-tighter mb-8">Let's Ignite Your Potential</h1>
      <p class="text-xl text-zinc-400 mb-6">
        Book a free 30-minute Discovery Call with Grant and take the first step toward real, lasting change.
      </p>
      <p class="text-zinc-500 mb-12">No pressure. No pitch. Just an honest conversation about where you are and where you want to be.</p>

      <a
        href="https://calendar.app.google/eaqMLr4bnVY8gYsu5"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block bg-amber-400 hover:bg-amber-500 text-black px-12 py-5 rounded-full text-xl font-semibold transition mb-16"
      >
        Book Your Discovery Call
      </a>

      <div class="grid md:grid-cols-3 gap-8 text-left mt-4">
        <div class="bg-zinc-900 rounded-2xl p-6 border border-white/10">
          <div class="text-2xl mb-3">📅</div>
          <h3 class="font-semibold mb-2">Pick a time</h3>
          <p class="text-zinc-400 text-sm">Choose a slot that works for you — no back-and-forth emails.</p>
        </div>
        <div class="bg-zinc-900 rounded-2xl p-6 border border-white/10">
          <div class="text-2xl mb-3">💬</div>
          <h3 class="font-semibold mb-2">We talk</h3>
          <p class="text-zinc-400 text-sm">A genuine conversation about your goals, challenges, and what's possible.</p>
        </div>
        <div class="bg-zinc-900 rounded-2xl p-6 border border-white/10">
          <div class="text-2xl mb-3">🚀</div>
          <h3 class="font-semibold mb-2">You decide</h3>
          <p class="text-zinc-400 text-sm">If it's a fit, we map out the right coaching path for you.</p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
