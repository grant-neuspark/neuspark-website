---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Header current="services" />

  <section class="pt-24 pb-20">
    <div class="max-w-5xl mx-auto px-6">
      <h1 class="text-5xl font-bold tracking-tighter mb-4 text-center">Coaching Programs</h1>
      <p class="text-center text-zinc-400 text-xl mb-16">Choose the level of support that fits your goals</p>

      <div class="grid md:grid-cols-2 gap-10">
        <div class="bg-zinc-900 border border-white/10 rounded-3xl p-10">
          <h3 class="text-3xl font-semibold mb-4">1:1 Deep Coaching</h3>
          <p class="text-amber-400 text-5xl font-light mb-8">Custom</p>
          <ul class="space-y-4 text-zinc-300">
            <li>✓ Weekly private sessions</li>
            <li>✓ Personalized transformation plan</li>
            <li>✓ Unlimited voice/text support</li>
            <li>✓ Deep mindset & behavioral work</li>
          </ul>
          <a href="/contact" class="block mt-12 text-center bg-amber-400 text-black py-4 rounded-2xl font-semibold">Apply Now</a>
        </div>

        <div class="bg-zinc-900 border border-white/10 rounded-3xl p-10">
          <h3 class="text-3xl font-semibold mb-4">Intensive Breakthrough</h3>
          <p class="text-amber-400 text-5xl font-light mb-8">3-Month</p>
          <ul class="space-y-4 text-zinc-300">
            <li>✓ 12 focused sessions</li>
            <li>✓ Goal achievement roadmap</li>
            <li>✓ High-performance habits</li>
            <li>✓ Accountability & momentum</li>
          </ul>
          <a href="/contact" class="block mt-12 text-center bg-amber-400 text-black py-4 rounded-2xl font-semibold">Learn More</a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
