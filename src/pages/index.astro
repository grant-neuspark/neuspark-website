---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Header current="home" />

  <!-- Hero -->
  <section class="min-h-screen flex items-center justify-center relative overflow-hidden bg-gradient-to-br from-zinc-950 via-zinc-900 to-black">
    <div class="max-w-5xl mx-auto px-6 text-center pt-20">
      <img src="/neuspark-logo.png" alt="NeuSpark" class="h-20 mx-auto mb-8">
      <h1 class="text-6xl md:text-7xl font-bold tracking-tighter leading-tight mb-6">
        IGNITING<br>YOUR POTENTIAL
      </h1>
      <p class="text-2xl md:text-3xl text-zinc-400 max-w-3xl mx-auto mb-10">
        Results-driven life coaching with Grant Jackson.<br>
        Break through limitations and create the life you were meant to live.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="bg-amber-400 hover:bg-amber-500 text-black px-10 py-4 rounded-full text-lg font-semibold transition">
          Begin Your Transformation
        </a>
        <a href="/about" class="border border-white/30 hover:bg-white/5 px-10 py-4 rounded-full text-lg font-medium transition">
          Meet Grant
        </a>
      </div>
    </div>
  </section>

  <!-- Trust bar -->
  <section class="py-8 border-b border-white/10 bg-black">
    <div class="max-w-5xl mx-auto px-6 text-center text-zinc-500 text-sm tracking-widest">
      Trusted by high-performers • Real results • Deep transformation
    </div>
  </section>

  <!-- Quick Benefits -->
  <section class="py-24 bg-zinc-950">
    <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-3 gap-12">
      <div class="text-center">
        <div class="text-5xl mb-6">🎯</div>
        <h3 class="text-2xl font-semibold mb-3">Clarity & Direction</h3>
        <p class="text-zinc-400">Cut through confusion and align with what truly matters to you.</p>
      </div>
      <div class="text-center">
        <div class="text-5xl mb-6">🔥</div>
        <h3 class="text-2xl font-semibold mb-3">Breakthrough Results</h3>
        <p class="text-zinc-400">Overcome mental blocks and take decisive action toward your goals.</p>
      </div>
      <div class="text-center">
        <div class="text-5xl mb-6">⚡</div>
        <h3 class="text-2xl font-semibold mb-3">Lasting Freedom</h3>
        <p class="text-zinc-400">Build unshakeable confidence and create sustainable life change.</p>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
